VITE_API_BASE_URL=https://api.crabbahia.com.ar/api

# Endpoints de auth (Laravel Sanctum Bearer token).
VITE_AUTH_LOGIN_ENDPOINT=/auth/login
VITE_AUTH_ME_ENDPOINT=/auth/me
